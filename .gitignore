.pio/
.vscode/
.DS_Store
*.swp

# PlatformIO IDF-component build: regenerated from sdkconfig.defaults each build
firmware/sdkconfig.cardputer
# Auto-generated src/CMakeLists.txt (PIO writes this if missing)
firmware/src/CMakeLists.txt
# Local serial-read helper
.read_serial.py

# Local Claude Code state — never commit
.claude/scheduled_tasks.lock
.claude/settings.local.json
wokwi-serial.log

# Per-device secrets (WiFi credentials, OTA password)
firmware/src/wifi_secrets.h

# Sealed-secrets workflow: plaintext input stays local; only the encrypted
# .sealed file under firmware/secrets/ is committed.
tools/hosts.json
tools/github_pat.txt
firmware/src/secrets/sealed_blobs.h

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Host-side ROM sync output (binaries — never commit, see web/roms-manifest.txt)
/roms-out/
# Private ROM manifest (commercial ROMs you legally own from your own storage)
web/roms-manifest.private.txt
