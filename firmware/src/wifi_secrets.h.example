#pragma once

// Copy this file to wifi_secrets.h and fill in your credentials. The
// destination is gitignored so values stay local. With no secrets file in
// place, the WiFi service stays disabled and OTA never starts.

#define CLAWD_WIFI_SSID "your-ssid"
#define CLAWD_WIFI_PASS "your-password"

// Optional: protect OTA flashing with a password. The PlatformIO OTA env
// passes the same value via `--auth=<password>` so set it in both places
// or leave both unset.
// #define CLAWD_OTA_PASSWORD "change-me"
